Authorization: Bearer {{token}}
Content-Type: application/json

{
  "firstName": "Zara",
  "lastName": "Ahmed",
  "email": "zara@gmail.com",
  "password": "Zara@12345",
  "role": "Receptionist",
  "phoneNo": "03007778899"
}

### Update User
PUT {{host}}/api/user/1
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "firstName": "John",
  "lastName": "Updated",
  "phoneNo": "03001234999",
  "isActive": true
}

### Delete User
DELETE {{host}}/api/user/1
Authorization: Bearer {{token}}

